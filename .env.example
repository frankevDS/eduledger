# Supabase project settings (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, NEVER expose to the browser or commit it.
# Used for: parent magic-link issuance, payment webhooks, other trusted server tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (https://console.groq.com/keys) — used for weekend-quiz auto-generation
GROQ_API_KEY=your-groq-api-key

# Paystack (or swap for Flutterwave/MoMo) — used to verify the payments webhook signature
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Base URL of this deployment, used when generating parent magic links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
